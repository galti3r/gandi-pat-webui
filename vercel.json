{
    "buildCommand": "bash build.sh",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/tokeninfo",
            "destination": "/api/tokeninfo"
        },
        {
            "source": "/v5/(.*)",
            "destination": "/api/v5/$1"
        }
    ],
    "headers": [
        {
            "source": "/(css|js|i18n)/:file*.:hash([a-f0-9]{8}).:ext(css|js|json)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache" }
            ]
        },
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache" }
            ]
        }
    ]
}
